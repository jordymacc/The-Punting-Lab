# The Punting Lab - Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Database Configuration
DATABASE_URL=sqlite:///./racing.db

# FormFav API Configuration (Required)
FORMFAV_BASE_URL=https://api.formfav.com
FORMFAV_API_KEY=your_api_key_here

# WebSocket Configuration
WS_TIMEOUT=30

# Scraping Configuration
SCRAPE_INTERVAL=60
MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
